# ===========================================
# AmkyawDev Tools — Environment Variables
# ===========================================

# --- OpenRouter (LLM) ---
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_DEFAULT_MODEL=anthropic/claude-sonnet-4.5

# --- Qdrant (Vector DB) ---
QDRANT_URL=https://your-qdrant-instance.qdrant.io
QDRANT_API_KEY=your-qdrant-api-key
QDRANT_COLLECTION_NAME=amkyawdev-tools

# --- Neon (PostgreSQL) ---
NEON_DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# --- ElevenLabs (TTS) ---
ELEVENLABS_API_KEY=your-elevenlabs-api-key
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# --- NVIDIA NIM (Optional fallback LLM) ---
NVIDIA_API_KEY=nvapi-your-key-here
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# --- Telegram Bot ---
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_WEBHOOK_SECRET=your-webhook-secret

# --- Backend ---
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
DEBUG=false
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws

# --- Aiven (Kafka + OpenSearch) ---
AIVEN_KAFKA_BROKER=your-kafka-broker.aivencloud.com:port
AIVEN_KAFKA_TOPIC=amkyawdev-events
AIVEN_OPENSEARCH_URL=https://your-opensearch.aivencloud.com:port
AIVEN_OPENSEARCH_INDEX=amkyawdev-logs
AIVEN_API_KEY=your-aiven-api-key

# --- Security ---
API_SECRET_KEY=change-this-to-a-random-secret
JWT_SECRET_KEY=change-this-to-another-random-secret
